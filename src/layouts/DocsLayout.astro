---
import Base from "../layouts/Base.astro";
interface Props { title?: string; section?: string }
const { title = "Docs", section = "" } = Astro.props;
const NAV = [
  { label:"Overview", href:"/docs" },
  { label:"Getting Started", href:"/docs/getting-started" },
  { label:"API Reference", href:"/docs/api" },
  { label:"Tutorials", href:"/docs/tutorials" },
  { label:"Changelog", href:"/docs/changelog" },
];
const path = Astro.url.pathname;
---
<Base title={`${title} — Docs`}>
  <nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-8 py-4 border-b border-void-700/50 backdrop-blur-xl bg-void-900/80">
    <a href="/" class="flex items-center gap-2.5">
      <img src="/logo.png" alt="Qwenta" class="w-7 h-7 rounded-lg" />
      <span class="font-display text-white italic">Qwenta</span>
      <span class="text-slate-500 font-mono text-sm">/</span>
      <span class="text-slate-400 font-mono text-sm">docs</span>
    </a>
    <a href="/dashboard" class="text-xs font-mono text-cyan-400 hover:text-cyan-300 transition-colors">→ Dashboard</a>
  </nav>

  <div class="flex min-h-screen pt-16">
    <!-- Sidebar -->
    <aside class="w-56 shrink-0 fixed left-0 top-16 bottom-0 border-r border-void-700 bg-void-900 overflow-y-auto py-8 px-4">
      <p class="text-[9px] font-mono text-void-500 uppercase tracking-widest px-2 mb-3">Documentation</p>
      {NAV.map(item => (
        <a href={item.href} class={`block px-3 py-2 rounded-lg text-sm font-sans transition-colors mb-0.5 ${path===item.href?"bg-cyan-500/10 text-cyan-400 border border-cyan-500/20":"text-slate-500 hover:text-slate-300 hover:bg-void-800"}`}>
          {item.label}
        </a>
      ))}
    </aside>

    <!-- Content -->
    <main class="ml-56 flex-1 max-w-4xl px-12 py-12">
      <slot />
    </main>
  </div>
</Base>

<style is:global>
  .prose h1 { font-family:'DM Serif Display',serif; font-size:2.5rem; color:white; margin-bottom:1rem; font-style:italic; }
  .prose h2 { font-family:'DM Serif Display',serif; font-size:1.75rem; color:#e2e8f0; margin-top:2.5rem; margin-bottom:0.75rem; border-bottom:1px solid #1a2238; padding-bottom:0.5rem; }
  .prose h3 { color:#94a3b8; font-size:1.125rem; font-weight:600; margin-top:1.5rem; margin-bottom:0.5rem; }
  .prose p { color:#64748b; line-height:1.75; margin-bottom:1rem; }
  .prose code { font-family:'JetBrains Mono',monospace; font-size:0.8rem; background:#0d1120; border:1px solid #1a2238; border-radius:4px; padding:0.15rem 0.4rem; color:#06b6d4; }
  .prose pre { background:#0a0d1a; border:1px solid #1a2238; border-radius:12px; padding:1.5rem; overflow-x:auto; margin:1.5rem 0; }
  .prose pre code { background:none; border:none; padding:0; color:#94a3b8; font-size:0.8rem; line-height:1.6; }
  .prose ul { color:#64748b; margin:1rem 0; padding-left:1.5rem; }
  .prose li { margin-bottom:0.4rem; }
  .prose a { color:#06b6d4; text-decoration:none; }
  .prose a:hover { text-decoration:underline; }
  .prose table { width:100%; border-collapse:collapse; margin:1.5rem 0; font-family:'JetBrains Mono',monospace; font-size:0.8rem; }
  .prose th { text-align:left; padding:0.5rem 1rem; background:#0d1120; color:#94a3b8; border:1px solid #1a2238; font-size:0.7rem; letter-spacing:0.1em; text-transform:uppercase; }
  .prose td { padding:0.5rem 1rem; border:1px solid #131929; color:#64748b; }
  .prose .badge-get { background:#22c55e18; color:#22c55e; border:1px solid #22c55e30; padding:0.15rem 0.5rem; border-radius:4px; font-size:0.7rem; font-family:'JetBrains Mono',monospace; }
  .prose .badge-post { background:#06b6d418; color:#06b6d4; border:1px solid #06b6d430; padding:0.15rem 0.5rem; border-radius:4px; font-size:0.7rem; font-family:'JetBrains Mono',monospace; }
  .prose .badge-delete { background:#f43f5e18; color:#f43f5e; border:1px solid #f43f5e30; padding:0.15rem 0.5rem; border-radius:4px; font-size:0.7rem; font-family:'JetBrains Mono',monospace; }
</style>
