---
import Base from "../layouts/Base.astro";
---
<Base title="Enterprise AI Trading Platform" description="Qwenta — Institutional-grade trading intelligence powered by private AI.">

<!-- ── NAVBAR ─────────────────────────────────────────────────────────── -->
<nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-4 md:px-8 py-3 md:py-4 border-b border-void-700/50 backdrop-blur-xl bg-void-900/80">
  <a href="/" class="flex items-center gap-2">
    <img src="/logo.png" alt="Qwenta" class="w-7 h-7 md:w-8 md:h-8 rounded-lg" />
    <span class="font-display text-white text-base md:text-lg italic">Qwenta</span>
    <span class="hidden sm:inline text-[9px] font-mono text-cyan-500 border border-cyan-500/30 px-1.5 py-0.5 rounded tracking-widest">ENTERPRISE</span>
  </a>

  <div class="hidden md:flex items-center gap-8 text-sm text-slate-400">
    <a href="#features" class="hover:text-cyan-400 transition-colors">Features</a>
    <a href="#security" class="hover:text-cyan-400 transition-colors">Security</a>
    <a href="#mobile" class="hover:text-cyan-400 transition-colors">Mobile</a>
    <a href="/docs" class="hover:text-cyan-400 transition-colors">Docs</a>
    <a href="#roadmap" class="hover:text-cyan-400 transition-colors">Roadmap</a>
    <a href="#token" class="hover:text-cyan-400 transition-colors">Token</a>
    <a href="https://x.com/qwenta_ai" target="_blank" rel="noopener noreferrer" class="hover:text-cyan-400 transition-colors" title="Follow us on X">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
    </a>
  </div>

  <a href="/login" class="flex items-center gap-2 px-3 md:px-5 py-2 bg-cyan-500/10 border border-cyan-500/30 rounded-lg text-cyan-400 text-xs md:text-sm font-medium hover:bg-cyan-500/20 transition-all hover:shadow-cyan-sm">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
    <span class="hidden sm:inline">Connect Wallet</span>
    <span class="sm:hidden">Connect</span>
  </a>
</nav>

<!-- ── HERO ───────────────────────────────────────────────────────────── -->
<section class="relative min-h-screen flex flex-col items-center justify-center text-center px-6 pt-20 overflow-hidden">
  <!-- Grid background -->
  <div class="absolute inset-0 bg-grid-void bg-grid opacity-100" />
  <!-- Glow -->
  <div class="absolute inset-0 bg-glow-hero" />
  <!-- Scan line -->
  <div class="absolute w-full h-[1px] bg-gradient-to-r from-transparent via-cyan-500/20 to-transparent animate-scan-line" />

  <div class="relative z-10 max-w-5xl mx-auto">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-cyan-500/20 bg-cyan-500/5 text-xs font-mono text-cyan-400 mb-8 animate-fade-in">
      <span class="w-1.5 h-1.5 rounded-full bg-cyan-400 animate-pulse" />
      Now with Qwen AI Analyst — Private, Secure, Fast
    </div>

    <!-- Headline -->
    <h1 class="font-display text-4xl sm:text-6xl md:text-8xl text-white mb-6 leading-none animate-slide-up" style="animation-delay:0.1s;opacity:0">
      Trade with<br/>
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-lime-400">
        Institutional
      </span><br/>
      Intelligence
    </h1>

    <p class="text-base sm:text-xl text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed animate-slide-up" style="animation-delay:0.2s;opacity:0">
      Real-time market data, advanced technical analysis, portfolio tracking, news sentiment, and private AI — all in one platform. Available on desktop and mobile.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center animate-slide-up" style="animation-delay:0.3s;opacity:0">
      <a href="/login" class="group relative px-8 py-3.5 bg-cyan-500 text-void-900 rounded-xl font-semibold text-sm hover:bg-cyan-400 transition-all shadow-cyan overflow-hidden">
        <span class="relative z-10 flex items-center gap-2">
          Connect Wallet & Enter
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </span>
      </a>
      <a href="/docs" class="px-8 py-3.5 border border-void-500 rounded-xl text-slate-300 text-sm font-medium hover:border-cyan-500/40 hover:text-cyan-300 transition-all">
        Read the Docs
      </a>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-4 gap-6 max-w-xl mx-auto mt-20 animate-slide-up" style="animation-delay:0.5s;opacity:0">
      {[["50+","Indicators"], ["100%","Private AI"], ["7","API Endpoints"], ["PWA","Mobile Ready"]].map(([val, label]) => (
        <div class="text-center">
          <p class="text-3xl font-display text-white">{val}</p>
          <p class="text-xs font-mono text-slate-500 mt-1 tracking-widest uppercase">{label}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Floating chart mockup -->
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-full max-w-4xl h-48 opacity-20 pointer-events-none">
    <svg viewBox="0 0 800 150" preserveAspectRatio="none" class="w-full h-full">
      <defs><linearGradient id="chartGrad" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#06b6d4" stop-opacity="0.4"/><stop offset="100%" stop-color="#06b6d4" stop-opacity="0"/></linearGradient></defs>
      <path d="M0,120 C50,100 80,80 120,70 S180,40 220,50 S280,90 320,60 S380,20 420,30 S480,80 520,40 S580,10 620,20 S680,60 720,30 S760,10 800,15 L800,150 L0,150 Z" fill="url(#chartGrad)"/>
      <path d="M0,120 C50,100 80,80 120,70 S180,40 220,50 S280,90 320,60 S380,20 420,30 S480,80 520,40 S580,10 620,20 S680,60 720,30 S760,10 800,15" fill="none" stroke="#06b6d4" stroke-width="1.5"/>
    </svg>
  </div>
</section>

<!-- ── FEATURES ────────────────────────────────────────────────────────── -->
<section id="features" class="py-16 sm:py-32 px-4 sm:px-6 relative">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-20">
      <p class="text-xs font-mono text-cyan-500 tracking-widest uppercase mb-3">Platform Capabilities</p>
      <h2 class="font-display text-3xl sm:text-5xl text-white">Everything you need<br/>to trade at the edge</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {[
        { icon:"◈", title:"Live Chart Engine", desc:"Multi-timeframe charts (1H–Weekly) with Bollinger Bands, SMA/EMA 20/50, RSI(14), MACD. Price, volume, and momentum in one view.", color:"text-cyan-400" },
        { icon:"◉", title:"Watchlist Manager", desc:"Multiple watchlists with live prices, daily change, market cap, and custom notes. PostgreSQL-backed, per-wallet isolated.", color:"text-lime-400" },
        { icon:"◎", title:"Portfolio Tracker", desc:"Track positions with weighted average cost. Real-time unrealized P&L, full transaction history, and portfolio summary.", color:"text-cyan-400" },
        { icon:"⊞", title:"Stock Screener", desc:"Filter the entire market by RSI range, MACD direction, SMA crossover, price range, and daily change %. Six built-in presets.", color:"text-lime-400" },
        { icon:"⊟", title:"Multi-Symbol Compare", desc:"Normalize and compare up to 6 symbols on the same chart. Period-relative return overlay with interactive tooltips.", color:"text-cyan-400" },
        { icon:"⬡", title:"Qwen AI Analyst", desc:"Private AI with full market context — OHLCV, indicators, fundamentals. Streaming responses. 100% local, no third-party access.", color:"text-lime-400" },
        { icon:"⬢", title:"News & Sentiment", desc:"Real-time financial news aggregation with AI-powered sentiment analysis. Bullish/bearish scoring per symbol, powered by Qwen.", color:"text-cyan-400" },
        { icon:"◊", title:"Multi-Wallet Auth", desc:"Sign-In with Ethereum (SIWE) or Solana. One click with MetaMask, Phantom, or Coinbase Wallet. No passwords required.", color:"text-lime-400" },
        { icon:"◻", title:"Full API & PWA", desc:"Seven RESTful endpoints with OpenAPI docs. Installable as a mobile app (PWA) on Android, iOS, and desktop.", color:"text-cyan-400" },
      ].map(f => (
        <div class="group p-6 rounded-2xl border border-void-600 bg-gradient-card hover:border-cyan-500/30 transition-all hover:shadow-card">
          <p class={`text-2xl mb-4 ${f.color}`}>{f.icon}</p>
          <h3 class="text-white font-semibold mb-2">{f.title}</h3>
          <p class="text-slate-500 text-sm leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── SECURITY ────────────────────────────────────────────────────────── -->
<section id="security" class="py-16 sm:py-32 px-4 sm:px-6 border-t border-void-700/50">
  <div class="max-w-4xl mx-auto text-center">
    <p class="text-xs font-mono text-lime-400 tracking-widest uppercase mb-3">Enterprise Security</p>
    <h2 class="font-display text-3xl sm:text-5xl text-white mb-6">Private by architecture</h2>
    <p class="text-slate-400 text-lg mb-16 leading-relaxed">No API keys sent to third parties. AI runs on dedicated infrastructure via Ollama. Your data is never shared. Your identity is your wallet.</p>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      {[
        { icon:"🔐", title:"Wallet Authentication", desc:"Sign in with MetaMask, Phantom, or Coinbase Wallet. Cryptographic proof of ownership. No passwords, no email." },
        { icon:"🖥️", title:"Private AI Engine", desc:"Qwen AI runs on dedicated infrastructure via Ollama. Zero data leaves the platform. Your queries stay private." },
        { icon:"🗄️", title:"Isolated Data Storage", desc:"Each wallet gets its own isolated data space. Watchlists, portfolios, and trades are never shared across accounts." },
      ].map(f => (
        <div class="p-6 rounded-2xl border border-void-600 bg-void-800/50 text-left">
          <p class="text-3xl mb-4">{f.icon}</p>
          <h3 class="text-white font-semibold mb-2">{f.title}</h3>
          <p class="text-slate-500 text-sm leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── MOBILE APP ──────────────────────────────────────────────────────── -->
<section id="mobile" class="py-16 sm:py-32 px-4 sm:px-6 border-t border-void-700/50 relative overflow-hidden">
  <div class="absolute inset-0 bg-glow-hero opacity-30" />
  <div class="max-w-5xl mx-auto relative z-10">
    <div class="text-center mb-16">
      <p class="text-xs font-mono text-cyan-500 tracking-widest uppercase mb-3">Mobile Experience</p>
      <h2 class="font-display text-3xl sm:text-5xl text-white">Install Qwenta on<br/>your phone</h2>
      <p class="text-slate-400 text-lg mt-4 max-w-2xl mx-auto">Full trading dashboard in your pocket. Install as a native app — no app store needed.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
      <!-- Install steps -->
      <div class="space-y-4">
        {[
          { step:"1", icon:"🌐", title:"Open in your browser", desc:"Visit qwenta.xyz on Chrome (Android) or Safari (iOS)." },
          { step:"2", icon:"📲", title:"Tap Install / Add to Home Screen", desc:'On Android: tap the install banner or menu → "Install app". On iOS: tap Share → "Add to Home Screen".' },
          { step:"3", icon:"📱", title:"Launch like a native app", desc:"Qwenta opens fullscreen — no browser UI. Connect your wallet and trade instantly." },
        ].map(s => (
          <div class="flex gap-4 p-5 rounded-2xl border border-void-600 bg-void-800/50 hover:border-cyan-500/30 transition-all group">
            <div class="shrink-0 w-10 h-10 rounded-xl bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center text-cyan-400 font-mono font-bold text-sm">{s.step}</div>
            <div>
              <h3 class="text-white font-semibold text-sm mb-1 group-hover:text-cyan-300 transition-colors">{s.title}</h3>
              <p class="text-slate-500 text-xs leading-relaxed">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Feature highlights -->
      <div class="space-y-4">
        <div class="p-6 rounded-2xl border border-cyan-500/20 bg-cyan-500/5">
          <h3 class="text-cyan-400 font-semibold mb-3">What you get</h3>
          <ul class="space-y-2.5">
            {[
              "Fullscreen trading dashboard — no browser chrome",
              "Offline access to cached charts and data",
              "Home screen icon with Qwenta branding",
              "Instant load — static assets cached locally",
              "Push-ready architecture for future alerts",
              "Works on Android, iOS, and desktop",
            ].map(item => (
              <li class="flex items-start gap-2 text-sm text-slate-300">
                <span class="text-cyan-400 mt-0.5 shrink-0">✓</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="flex gap-3">
          <div class="flex-1 p-4 rounded-xl border border-void-600 bg-void-800/50 text-center">
            <svg class="w-7 h-7 mx-auto mb-1.5" viewBox="0 0 24 24" fill="none"><path d="M17.6 9.48l1.84-3.18a.39.39 0 00-.67-.39l-1.87 3.24A11.47 11.47 0 0012 8.01c-1.8 0-3.5.46-4.9 1.14L5.23 5.91a.39.39 0 00-.67.39L6.4 9.48A10.8 10.8 0 001 18h22a10.8 10.8 0 00-5.4-8.52zM7 15.25a1.25 1.25 0 110-2.5 1.25 1.25 0 010 2.5zm10 0a1.25 1.25 0 110-2.5 1.25 1.25 0 010 2.5z" fill="#3DDC84"/></svg>
            <p class="text-[10px] font-mono text-slate-400 tracking-widest">ANDROID</p>
            <p class="text-[9px] font-mono text-void-500 mt-0.5">Chrome 73+</p>
          </div>
          <div class="flex-1 p-4 rounded-xl border border-void-600 bg-void-800/50 text-center">
            <svg class="w-7 h-7 mx-auto mb-1.5" viewBox="0 0 24 24" fill="none"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" fill="#ffffff"/></svg>
            <p class="text-[10px] font-mono text-slate-400 tracking-widest">iOS</p>
            <p class="text-[9px] font-mono text-void-500 mt-0.5">Safari 14.1+</p>
          </div>
          <div class="flex-1 p-4 rounded-xl border border-void-600 bg-void-800/50 text-center">
            <svg class="w-7 h-7 mx-auto mb-1.5" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10.5" stroke="#4285F4" stroke-width="1.5" fill="none"/><path d="M21.35 11.1H12v2.85h5.35c-.5 2.45-2.6 3.75-5.35 3.75a5.9 5.9 0 01-5.9-5.9A5.9 5.9 0 0112 5.9c1.45 0 2.8.55 3.8 1.45l2.15-2.15A9.7 9.7 0 0012 2.25c-5.4 0-9.75 4.35-9.75 9.75S6.6 21.75 12 21.75c4.95 0 9.3-3.6 9.3-9.75 0-.6-.05-1.2-.15-1.75z" fill="#4285F4"/><path d="M3.65 7.35l2.5 1.85A5.85 5.85 0 0112 5.9c1.45 0 2.8.55 3.8 1.45l2.15-2.15A9.7 9.7 0 0012 2.25 9.72 9.72 0 003.65 7.35z" fill="#EA4335"/><path d="M12 21.75c2.55 0 4.85-.85 6.6-2.3l-2.35-1.95c-.95.7-2.15 1.1-3.45 1.3v.01c-2.7-.05-5-1.8-5.75-4.3l-2.5 1.95A9.72 9.72 0 0012 21.75z" fill="#34A853"/><path d="M3.65 16.65l2.5-1.95a5.85 5.85 0 01-.3-1.9c0-.65.1-1.3.3-1.9l-2.5-1.85A9.65 9.65 0 002.25 12c0 1.7.45 3.3 1.2 4.7z" fill="#FBBC05"/></svg>
            <p class="text-[10px] font-mono text-slate-400 tracking-widest">DESKTOP</p>
            <p class="text-[9px] font-mono text-void-500 mt-0.5">Chrome / Edge</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── ROADMAP ─────────────────────────────────────────────────────────── -->
<section id="roadmap" class="py-16 sm:py-32 px-4 sm:px-6 border-t border-void-700/50">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-xs font-mono text-cyan-500 tracking-widest uppercase mb-3">Product Roadmap</p>
      <h2 class="font-display text-3xl sm:text-5xl text-white">What's coming</h2>
    </div>
    <div class="space-y-4">
      {[
        { q:"Q1 2026", status:"done", items:["Live chart engine with RSI, MACD, Bollinger Bands, SMA/EMA","Watchlist & Portfolio tracking with PostgreSQL","Stock Screener with 6 presets and custom filters","Multi-symbol comparison with normalized returns","Multi-wallet auth — MetaMask, Phantom, Coinbase (SIWE)"] },
        { q:"Q2 2026", status:"done", items:["Qwen AI analyst with full market context and streaming","News & Sentiment — real-time news with AI-powered scoring","Export CSV/XLSX with full OHLCV + indicator data","Multi-timeframe support (1H, 4H, Daily, Weekly)","Full API documentation with OpenAPI spec"] },
        { q:"Q3 2026", status:"done", items:["Mobile PWA — installable on Android, iOS, and desktop","Mobile-responsive dashboard with drawer navigation","Service worker with offline caching strategy","Full API documentation (7 endpoints)"] },
        { q:"Q4 2026", status:"active", items:["Real-time WebSocket price feeds","Price alert system (push notifications + webhook)","Backtesting engine for simple strategies","Advanced AI models with custom fine-tuning"] },
        { q:"2027", status:"planned", items:["Multi-chain portfolio (Ethereum, Solana, Base)","On-chain DeFi position tracking","Team workspaces with role-based access controls","Automated strategy execution hooks","White-label deployment for institutions"] },
      ].map(phase => (
        <div class={`p-5 rounded-2xl border ${phase.status==="done"?"border-lime-500/20 bg-lime-500/5":phase.status==="active"?"border-cyan-500/30 bg-cyan-500/5":"border-void-600 bg-void-850"}`}>
          <div class="flex items-center gap-3 mb-3">
            <span class={`text-xs font-mono font-semibold tracking-widest px-2 py-0.5 rounded ${phase.status==="done"?"bg-lime-500/10 text-lime-400":phase.status==="active"?"bg-cyan-500/10 text-cyan-400":"text-slate-600 bg-void-600/50"}`}>
              {phase.status==="done"?"✓ SHIPPED":phase.status==="active"?"⚡ IN PROGRESS":"◦ PLANNED"}
            </span>
            <span class="font-mono text-sm text-slate-400">{phase.q}</span>
          </div>
          <ul class="space-y-1">
            {phase.items.map(item => (
              <li class={`text-sm flex items-start gap-2 ${phase.status==="done"?"text-slate-300":phase.status==="active"?"text-cyan-200":"text-slate-600"}`}>
                <span class="mt-0.5 shrink-0">{phase.status==="done"?"✓":phase.status==="active"?"›":"·"}</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── TOKEN ──────────────────────────────────────────────────────────── -->
<section id="token" class="py-16 sm:py-32 px-4 sm:px-6 border-t border-void-700/50 relative overflow-hidden">
  <div class="absolute inset-0 bg-glow-hero opacity-20" />
  <div class="max-w-3xl mx-auto relative z-10">
    <div class="text-center mb-12">
      <p class="text-xs font-mono text-lime-400 tracking-widest uppercase mb-3">Platform Token</p>
      <h2 class="font-display text-3xl sm:text-5xl text-white mb-4">$QWENTA</h2>
      <p class="text-slate-400 text-lg max-w-xl mx-auto">The native utility token powering the Qwenta ecosystem. Access premium features, governance, and rewards.</p>
    </div>

    <div class="bg-void-800/80 backdrop-blur-sm border border-void-600 rounded-2xl p-6 sm:p-8 shadow-panel">
      <!-- Token info grid -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
        {[
          ["Token Name", "QWENTA"],
          ["Ticker", "$QWENTA"],
          ["Network", "TBA"],
          ["Status", "Coming Soon"],
        ].map(([label, value]) => (
          <div class="bg-void-850 border border-void-700 rounded-xl p-3 text-center">
            <p class="text-[9px] font-mono text-void-500 uppercase tracking-widest mb-1">{label}</p>
            <p class="text-sm font-mono text-white font-semibold">{value}</p>
          </div>
        ))}
      </div>

      <!-- Contract address -->
      <div class="bg-void-850 border border-void-700 rounded-xl p-4 mb-6">
        <div class="flex items-center justify-between mb-2">
          <p class="text-[9px] font-mono text-void-500 uppercase tracking-widest">Contract Address</p>
          <span class="text-[9px] font-mono text-cyan-400 bg-cyan-500/10 border border-cyan-500/20 px-2 py-0.5 rounded tracking-widest">COMING SOON</span>
        </div>
        <div class="flex items-center gap-3 bg-void-900/50 border border-void-600 rounded-lg px-4 py-3">
          <svg class="w-5 h-5 text-void-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          <span class="font-mono text-sm text-void-500 tracking-wider">0x000...0000</span>
          <span class="ml-auto text-[8px] font-mono text-void-600 uppercase">Not deployed</span>
        </div>
      </div>

    </div>

    <p class="text-center text-[10px] font-mono text-void-600 mt-6">Token details including network, supply, and launch date will be announced on our official channels.</p>
  </div>
</section>

<!-- ── CTA ─────────────────────────────────────────────────────────────── -->
<section class="py-16 sm:py-32 px-4 sm:px-6 border-t border-void-700/50 text-center relative overflow-hidden">
  <div class="absolute inset-0 bg-glow-hero opacity-50" />
  <div class="relative z-10 max-w-2xl mx-auto">
    <h2 class="font-display text-3xl sm:text-5xl text-white mb-6">Ready to gain the edge?</h2>
    <p class="text-slate-400 mb-10 text-lg">Connect your wallet and access the full platform instantly. No sign-up. No subscription. Just connect.</p>
